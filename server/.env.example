# Get this from Neon (https://neon.tech) -> Project -> Connection details
# Use the "Pooled connection" string. Example:
# postgres://USER:PASSWORD@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Long random string. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-something-long-and-random

# Allowed origin for the Next.js frontend (used for CORS)
CLIENT_ORIGIN=http://localhost:3000

# Auto-created on first boot if no super admin exists.
SUPER_ADMIN_EMAIL=admin@clipper.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Admin

PORT=4000
NODE_ENV=development
